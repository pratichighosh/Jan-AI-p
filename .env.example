# App
APP_ENV=development
APP_PORT=8000
SECRET_KEY=change-this-to-a-random-string-in-production

# Bhashini API — get from https://bhashini.gov.in/ulca/user/register
BHASHINI_API_KEY=your_bhashini_key_here
BHASHINI_USER_ID=your_bhashini_user_id_here
BHASHINI_PIPELINE_ID=64392f96daac500b55c543cd

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=cais_db
POSTGRES_USER=cais_user
POSTGRES_PASSWORD=cais_password

# MongoDB
MONGO_URI=mongodb://localhost:27017
MONGO_DB=cais_documents

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# OCR
OCR_CONFIDENCE_THRESHOLD=0.7
MAX_FILE_SIZE_MB=10

# LLM (optional for now — can use rule-based fallback)
# SARVAM_API_KEY=your_sarvam_key_here